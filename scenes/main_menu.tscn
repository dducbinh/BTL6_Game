theme_override_font_sizes/font_size = 24
text = "Quit"

[connection signal="pressed" from="VBoxContainer/PvEButton" to="." method="_on_pve_button_pressed"]
[connection signal="pressed" from="VBoxContainer/PvPButton" to="." method="_on_pvp_button_pressed"]
[connection signal="pressed" from="VBoxContainer/CoopButton" to="." method="_on_coop_button_pressed"]
[connection signal="pressed" from="VBoxContainer/QuitButton" to="." method="_on_quit_button_pressed"]
